# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="mysql://root@localhost:3306/cotizaciones_frank"

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# AWS S3
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=cotizador-docs

# Email (Nodemailer SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=Cotizador

# Admin notification email (receives alerts when clients accept/reject quotes)
ADMIN_NOTIFICATION_EMAIL=admin@example.com

# Client Portal URL (used in email links)
PORTAL_URL=http://localhost:3001/portal
